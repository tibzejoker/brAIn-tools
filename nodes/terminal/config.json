{
  "name": "terminal",
  "description": "Executes shell commands received via messages and publishes stdout/stderr. Configure allowed_commands and cwd via config_overrides.",
  "tags": [
    "utility",
    "shell",
    "terminal"
  ],
  "default_authority": 1,
  "default_priority": 3,
  "ports": {
    "outputs": {
      "terminal.output": {
        "description": "terminal.output"
      }
    }
  },
  "default_port_bindings": {
    "outputs": {
      "terminal.output": [
        "terminal.output"
      ]
    }
  },
  "supports_transport": [
    "process"
  ]
}
