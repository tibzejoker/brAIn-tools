{
  "name": "http-bridge",
  "description": "Bridges the network to HTTP. Receives messages on subscribed topics and makes HTTP requests. Publishes responses back.",
  "tags": [
    "utility",
    "http",
    "bridge"
  ],
  "default_authority": 0,
  "default_priority": 3,
  "ports": {
    "outputs": {
      "http.response": {
        "description": "http.response"
      }
    }
  },
  "default_port_bindings": {
    "outputs": {
      "http.response": [
        "http.response"
      ]
    }
  },
  "supports_transport": [
    "process"
  ]
}
